# --- Database ---
# Your MongoDB Cluster connection string
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# --- Authentication ---
# A secure random string for JWT signing
JWT_SECRET=your_jwt_secret_here
# The secret key used for initial admin setup
ADMIN_KEY=your_setup_key_here

# --- Email Service (Resend) ---
# Your Resend API key for contact form notifications
RESEND_API_KEY=re_your_api_key_here

# --- Frontend (Optional) ---
# Only needed if you want to point to a specific API port during local development
# VITE_API_URL=http://localhost:4000/api
